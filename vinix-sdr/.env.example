# ============================================================================
# VINIX SDR — Variables de entorno
# Copia este archivo como .env.local y rellena los valores reales.
# ⚠️ Tras editar .env.local, REINICIA el servidor (Ctrl+C → npm run dev):
#    Next.js sólo lee las variables al arrancar.
#
# Leyenda:  [CRÍTICA] la app no arranca sin ella
#           [NECESARIA] una función concreta queda desactivada
#           [OPCIONAL] mejora el comportamiento pero hay alternativa
# ============================================================================

# ── SUPABASE ────────────────────────────────────────────────────────────────
# Dónde: supabase.com → tu proyecto → Settings (engranaje) → API
#
# [CRÍTICA] Project URL. Se necesita también con prefijo NEXT_PUBLIC_ porque
# el login ocurre en el navegador.
SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# [CRÍTICA] service_role → Reveal.
# ⚠️ BYPASEA RLS: sólo en servidor, nunca en cliente ni en Git.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# [CRÍTICA] anon public. Es la clave del navegador; está sujeta a RLS, así que
# es segura de exponer. Sin ella no hay login de usuarios.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── OPENAI ──────────────────────────────────────────────────────────────────
# [CRÍTICA] platform.openai.com → API keys → Create new secret key
# Requiere método de pago en Settings → Billing (~0,001 € por lead procesado).
OPENAI_API_KEY=sk-...
# [OPCIONAL] Cambiar de modelo sin tocar código (por defecto gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# ── RESEND (envío y recepción de emails) ────────────────────────────────────
# Dónde: resend.com → API Keys → Create API Key
#
# [NECESARIA] Sin ella no se pueden enviar emails (sí investigar y redactar).
RESEND_API_KEY=re_...
# [NECESARIA] resend.com → Webhooks → tu endpoint → Signing Secret.
# Sin ella no se clasifican las respuestas entrantes.
RESEND_WEBHOOK_SECRET=whsec_...
# [NECESARIA] Remitente por defecto. Debe pertenecer a un dominio verificado
# en Resend → Domains. Cada campaña puede sobreescribirlo.
SENDER_NAME=Jorge
SENDER_EMAIL=jorge@tudominio.com

# ── STRIPE (suscripciones) ──────────────────────────────────────────────────
# Dónde: dashboard.stripe.com → Developers → API keys
#
# [NECESARIA] Sin ella no se puede cobrar (la app funciona en modo trial/free).
STRIPE_SECRET_KEY=sk_test_...
# [NECESARIA] Developers → Webhooks → tu endpoint → Signing secret.
# Es lo ÚNICO que concede un plan de pago: sin ella, nadie sube de plan.
STRIPE_WEBHOOK_SECRET=whsec_...

# [NECESARIAS] Price IDs de cada plan y ciclo.
# Dónde: Products → crea "Pro" y "Agency", cada uno con un precio mensual y
# otro anual recurrentes → copia el id de cada precio (price_...).
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_AGENCY_MONTHLY=price_...
STRIPE_PRICE_AGENCY_ANNUAL=price_...

# ── FIRECRAWL ───────────────────────────────────────────────────────────────
# [OPCIONAL] firecrawl.dev → Dashboard → API Keys
# Sin ella el scraping usa fetch simple: vale para webs estáticas, no para
# SPAs que renderizan con JavaScript.
FIRECRAWL_API_KEY=fc-...

# ── APLICACIÓN ──────────────────────────────────────────────────────────────
# [NECESARIA en producción] URL pública. Stripe la usa para las redirecciones
# de vuelta tras el pago. En local puede omitirse (por defecto localhost:3000).
NEXT_PUBLIC_SITE_URL=https://tu-app.vercel.app

# [NECESARIA en producción] Protege el cron de follow-ups de vercel.json.
# Genera un valor aleatorio largo: openssl rand -hex 32
CRON_SECRET=

# [OPCIONAL] Nivel de log: debug | info | warn | error
# Por defecto: debug en desarrollo, info en producción.
# LOG_LEVEL=info

# [OPCIONAL] Captura de errores. Con esta variable definida, captureException()
# marca los errores como reportables (requiere instalar @sentry/nextjs).
# SENTRY_DSN=
